<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ShowHistoryController">
   <children>
      <!-- Title -->
      <Label layoutX="50.0" layoutY="20.0" prefWidth="900.0" text="Visit History" wrapText="true">
          <font><Font name="System Bold" size="24.0" /></font>
      </Label>
      
      <!-- Subscriber ID Display -->
      <Label fx:id="lblSubscriberID" layoutX="50.0" layoutY="60.0" prefWidth="900.0" text="Subscriber ID: " wrapText="true">
          <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      
      <!-- Status Label -->
      <Label fx:id="lblStatus" alignment="CENTER" layoutX="50.0" layoutY="100.0" prefHeight="30" prefWidth="900" textAlignment="CENTER" wrapText="true">
          <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      
      <!-- Table View -->
      <TableView fx:id="historyTable" layoutX="50.0" layoutY="140.0" prefHeight="380.0" prefWidth="1100.0">
        <columns>
          <TableColumn fx:id="colCreatedAt" prefWidth="180.0" text="Created At" />
          <TableColumn fx:id="colStartTime" prefWidth="180.0" text="Start Time" />
          <TableColumn fx:id="colConfirmationCode" prefWidth="200.0" text="Confirmation Code" />
          <TableColumn fx:id="colNumberOfGuests" prefWidth="150.0" text="Number of Guests" />
          <TableColumn fx:id="colFinalAmount" prefWidth="180.0" text="Final Amount" />
        </columns>
      </TableView>
      
      <!-- Back Button -->
      <Button fx:id="btnBack" layoutX="450.0" layoutY="540.0" onAction="#Back" prefWidth="200.0" prefHeight="40.0" text="Back" />
   </children>
</AnchorPane>

